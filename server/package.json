{
  "name": "json-sort-server",
  "version": "0.1.0",
  "description": "LSP server for the Zed JSON Sort extension.",
  "main": "index.js",
  "private": true,
  "scripts": {
    "test": "node --test 'test/**/*.test.js'",
    "start": "node index.js --stdio",
    "build": "esbuild index.js --bundle --platform=node --target=node18 --format=cjs --main-fields=module,main --keep-names --outfile=../dist/server.bundle.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "jsonc-parser": "^3.3.1",
    "json5": "^2.2.3",
    "lossless-json": "^4.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.23.0"
  }
}
